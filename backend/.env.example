# Required — get a free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — free tiers used to spread agents across providers.
# If a key is missing, that provider's agents fall back to Gemini.
GROQ_API_KEY=          # https://console.groq.com
HF_TOKEN=              # https://huggingface.co/settings/tokens

# Optional but recommended — grounding/citations. Tavily is the primary source
# (real URLs, dedicated free tier); Gemini Google Search is the fallback.
TAVILY_API_KEY=        # free key at https://tavily.com

# Optional — max agents running concurrently (default 4)
AGENT_CONCURRENCY=4

PORT=3001
